{
  "devices": [
    {
      "id": "virtual-fans",
      "label": "Virtual Fans",
      "channels": [
        {
          "id": "fan1",
          "label": "Fan 1",
          "commands": {
            "get_rpm": "cat /sys/class/hwmon/hwmon3/fan1_input",
            "get_duty": "echo $(($(cat /sys/class/hwmon/hwmon3/pwm1) * 100 / 255))",
            "set_duty": "echo $(({duty} * 255 / 100)) > /sys/class/hwmon/hwmon3/pwm1",
            "enable_manual": "echo 1 > /sys/class/hwmon/hwmon3/pwm1_enable",
            "reset": "echo 2 > /sys/class/hwmon/hwmon3/pwm1_enable"
          }
        }
      ],
      "temps": [
        {
          "id": "temp1",
          "label": "GPU Temp",
          "command": "cat /sys/class/hwmon/hwmon3/temp1_input"
        }
      ]
    }
  ]
}